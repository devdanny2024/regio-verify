# Server
PORT=3000

# Admin panel credentials
ADMIN_USER=admin
ADMIN_PASS=changeme

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/regio_verify

# Matrix homeserver (Synapse)
MATRIX_HOMESERVER=https://matrix.example.com

# Bot user and its password (used to auto-refresh expired access tokens)
MATRIX_BOT_TOKEN=syt_your_bot_token_here
MATRIX_BOT_USER_ID=@bot-user:example.com
MATRIX_BOT_PASS=your_bot_password_here

# Admin Matrix user — invited into every verification room automatically
MATRIX_ADMIN_USER_ID=@admin:example.com

# Real name shown to the member as "You're talking to {name}" (falls back to
# "REGIO Team" if unset — do not use the Matrix localpart, it's not a name)
ADMIN_DISPLAY_NAME=Jane Doe

# Registration token — issued by the Synapse homeserver admin
MATRIX_REGISTRATION_TOKEN=your_registration_token_here

# Public base URL — used to build invite links shown in admin panel
BASE_URL=https://verify.example.com

# SMTP — local Postfix smart relay (no auth, no TLS on port 25)
SMTP_HOST=127.0.0.1
SMTP_PORT=25
SMTP_SECURE=false
SMTP_FROM=REGIO Verify <noreply@example.com>
# If the Postfix relay account domain differs from SMTP_FROM domain, set this
# to the relay account address so Migadu accepts the envelope sender.
SMTP_ENVELOPE_FROM=mailer@relay-account.example.com
